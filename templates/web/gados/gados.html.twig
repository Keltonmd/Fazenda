{% extends 'base.html.twig' %}

{% block title %}Gados Vivos{% endblock %}
{% block page_title %}Gados Vivos{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Gados</li>{% endblock %}

{% block extra_css %}
  <link rel="stylesheet" href="{{ asset('css/gados/gados.css') }}">
{% endblock %}

{% block body %}

<div class="page-toolbar">
  <h5>
    <i class="fa-solid fa-cow" aria-hidden="true"></i>
    Lista de Gados Vivos
    <span class="badge-count ms-1" id="badge-gados-count">0</span>
  </h5>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalGado" id="btn-novo-gado">
    <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> Novo Gado
  </button>
</div>

{# ── FILTROS ── #}
<div class="card mb-3">
  <div class="card-body py-2">
    <div class="row g-2 align-items-end">
      <div class="col-12 col-sm-6 col-md-4">
        <div class="search-wrap">
          <i class="bi bi-search search-icon" aria-hidden="true"></i>
          <input type="text" id="filtro-gado-q"
                 class="form-control form-control-sm"
                 placeholder="Buscar por código..."
                 aria-label="Buscar gado por código">
        </div>
      </div>
      <div class="col-6 col-sm-4 col-md-3">
        <select id="filtro-gado-fazenda" class="form-select form-select-sm" aria-label="Filtrar por fazenda">
          <option value="">Fazenda</option>
        </select>
      </div>
      <div class="col-auto">
        <button type="button" class="btn btn-sm btn-light" id="btn-limpar-filtro-gado">
          <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Limpar
        </button>
      </div>
    </div>
  </div>
</div>

{# ── TABELA ── #}
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Código</th>
          <th>Peso (kg)</th>
          <th class="d-none d-md-table-cell">Leite (L/sem)</th>
          <th class="d-none d-md-table-cell">Ração (kg/sem)</th>
          <th class="d-none d-sm-table-cell">Nascimento</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody id="gados-tbody">
        <tr><td colspan="6" class="text-center text-muted py-5">
          <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Carregando gados...
        </td></tr>
      </tbody>
    </table>
  </div>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <button class="btn btn-sm btn-light" id="btn-prev">
      <i class="bi bi-chevron-left"></i> Anterior
    </button>

    <span id="pagination-info" class="text-muted small">
      Página 1 de 1
    </span>

    <button class="btn btn-sm btn-light" id="btn-next">
      Próxima <i class="bi bi-chevron-right"></i>
    </button>
  </div>
</div>

{# ════ MODAL CADASTRO/EDIÇÃO GADO ════ #}
<div class="modal fade" id="modalGado" tabindex="-1" aria-labelledby="modalGadoTitle" aria-modal="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form id="formGado">
        <input type="hidden" id="gadoId">

        <div class="modal-header">
          <h5 class="modal-title" id="modalGadoTitle">
            <i class="fa-solid fa-cow" aria-hidden="true"></i> Novo Gado
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-6 col-md-4">
              <label class="form-label" for="gadoCodigo">Código</label>
              <input type="number" id="gadoCodigo" class="form-control" placeholder="Ex.: 1" min="1" step="1">
            </div>
            <div class="col-6 col-md-4">
              <label class="form-label" for="gadoPeso">Peso (kg) <span class="text-danger" aria-hidden="true">*</span></label>
              <input type="number" id="gadoPeso" class="form-control"
                     step="0.1" min="0" placeholder="0.0" required aria-required="true">
            </div>
            <div class="col-6 col-md-4">
              <label class="form-label" for="gadoLeite">Leite (L/semana)</label>
              <input type="number" id="gadoLeite" class="form-control" step="1" min="0" placeholder="0">
            </div>
            <div class="col-6 col-md-4">
              <label class="form-label" for="gadoRacao">Ração (kg/semana)</label>
              <input type="number" id="gadoRacao" class="form-control" step="0.1" min="0" placeholder="0.0">
            </div>
            <div class="col-6 col-md-4">
              <label class="form-label" for="gadoNascimento">Data de Nascimento <span class="text-danger" aria-hidden="true">*</span></label>
              <input type="date" id="gadoNascimento" class="form-control" required aria-required="true">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label" for="gadoFazenda">Fazenda <span class="text-danger" aria-hidden="true">*</span></label>
              <select id="gadoFazenda" class="form-select" required aria-required="true">
                <option value="">Selecione a fazenda</option>
              </select>
            </div>
          </div>
          <div id="gado-form-feedback" class="mt-3" role="alert" aria-live="polite"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
            <span id="gadoBtnLabel">Cadastrar gado</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

{# ════ MODAL CANCELAR ABATE ════ #}
<div class="modal fade" id="modalCancelarAbateGado" tabindex="-1" aria-labelledby="modalCancelarAbateGadoTitle" aria-modal="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalCancelarAbateGadoTitle">
          <i class="bi bi-arrow-counterclockwise text-warning" aria-hidden="true"></i>
          Cancelar Abate
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <p class="mb-2">
          Tem certeza que deseja cancelar o abate de
          <strong id="cancelar-abate-gado-nome-inline"></strong>?
        </p>
        <p class="text-muted small mb-3">
          Se já existir outro gado vivo com o mesmo código, informe um novo código para reativar este animal.
        </p>
        <div id="novo-codigo-wrap-inline" class="mb-3" style="display: none;">
          <label for="novo-codigo-input-inline" class="form-label">Novo código</label>
          <input type="number" id="novo-codigo-input-inline" class="form-control"
                 min="1" step="1" placeholder="Informe um novo código">
        </div>
        <div id="cancelar-abate-feedback-inline" role="alert" aria-live="polite"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fechar</button>
        <button type="button" class="btn btn-warning" id="btn-confirmar-cancelar-abate-inline">
          <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Cancelar abate
        </button>
      </div>
    </div>
  </div>
</div>

{# ════ MODAL EXCLUIR GADO ════ #}
<div class="modal fade" id="modalDeleteGado" tabindex="-1" aria-labelledby="modalDeleteGadoTitle" aria-modal="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-body pt-4 pb-2 px-4 text-center">
        <div class="modal-confirm-icon-wrap danger">
          <i class="bi bi-trash3-fill" aria-hidden="true"></i>
        </div>
        <p class="fw-semibold mb-1" style="font-size:.95rem;">
          Excluir <strong id="delete-gado-nome"></strong>?
        </p>
        <p class="text-muted" style="font-size:.82rem;">Esta ação remove o cadastro do animal de forma definitiva.</p>
      </div>
      <div class="modal-footer justify-content-center border-0 pb-4 gap-2">
        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">
          <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Cancelar
        </button>
        <button type="button" class="btn btn-danger px-4" id="btn-confirmar-delete-gado">
          <i class="bi bi-trash3 me-1" aria-hidden="true"></i>Excluir
        </button>
      </div>
    </div>
  </div>
</div>

{% endblock %}

{% block extra_js %}
  <script src="{{ asset('js/gados/gados.js') }}"></script>
{% endblock %}
