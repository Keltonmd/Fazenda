{% extends 'layout/auth.html.twig' %}

{% block title %}Login{% endblock %}

{% block extra_css %}
  <link rel="stylesheet" href="{{ asset('css/auth/login.css') }}">
{% endblock %}

{% block body %}
<main class="auth-page" id="login-page">

  <div class="auth-card">

    {# ── Logo ── #}
    <div class="auth-logo">
      <div class="auth-logo-icon">
        <img
          src="{{ asset('img/logo.png') }}"
          alt="AgroPanel — Sistema de Gestão Agropecuária"
          class="logo logo--auth"
          width="54"
          height="54"
        >
      </div>
      <div class="auth-logo-text">
        <span class="auth-logo-name">AgroPanel</span>
        <span class="auth-logo-sub">Gestão Agropecuária</span>
      </div>
    </div>

    {# ── Título ── #}
    <h1 class="auth-title">Bem-vindo de volta</h1>
    <p class="auth-subtitle">Informe seu e-mail e senha para acessar o painel.</p>

    {# ── Formulário ── #}
    <form id="loginForm" method="post" action="#" novalidate>

      {# E-mail #}
      <div class="auth-input-group">
        <label class="auth-label" for="loginEmail">E-mail</label>
        <div style="position:relative;">
          <i class="bi bi-envelope auth-input-icon"></i>
          <input
            type="email"
            id="loginEmail"
            name="email"
            class="auth-input"
            placeholder="seu@email.com"
            required
            autocomplete="username"
          >
        </div>
      </div>

      {# Senha #}
      <div class="auth-input-group">
        <label class="auth-label" for="loginPassword">Senha</label>
        <div style="position:relative;">
          <i class="bi bi-lock auth-input-icon"></i>
          <input
            type="password"
            id="loginPassword"
            name="password"
            class="auth-input has-toggle"
            placeholder="Sua senha"
            required
            autocomplete="current-password"
          >
          <button
            type="button"
            id="toggleLoginPassword"
            class="auth-toggle-pw"
            aria-label="Mostrar/ocultar senha"
            tabindex="-1"
          >
            <i class="bi bi-eye" id="toggleLoginPasswordIcon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="auth-btn" id="login-submit-btn">
        <span id="login-btn-content">
          <i class="bi bi-box-arrow-in-right me-1"></i> Entrar no painel
        </span>
      </button>

      <div class="auth-feedback" id="loginFeedback" role="alert" aria-live="polite"></div>

    </form>

    <hr class="auth-divider">

    <p class="auth-switch">
      Não tem conta?
      <a href="{{ path('register') }}">Criar conta</a>
    </p>

  </div>

</main>
{% endblock %}

{% block extra_js %}
  <script src="{{ asset('js/auth/login.js') }}"></script>
{% endblock %}
